# Server configuration — copy to .env and fill in.
PORT=4000

# MongoDB Atlas free-tier connection string.
MONGODB_URI=

# Free AI Studio key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Pinned free Flash model. Confirm the live name in AI Studio for your region.
GEMINI_MODEL=gemini-3.1-flash-lite

# Allowed browser origin for CORS (Vite dev default).
CLIENT_ORIGIN=http://localhost:5173
