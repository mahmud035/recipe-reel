# Server configuration — copy to .env and fill in.
PORT=5000

# MongoDB Atlas free-tier connection string.
MONGODB_URI=

# Free AI Studio key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Pinned free Flash model. Confirm the live name in AI Studio for your region.
GEMINI_MODEL=gemini-3.1-flash-lite

# Comma-separated allowlist of browser origins for CORS.
# Prod example: https://recipe-reel.vercel.app,https://lab-recipe-reel.halalaura.co.uk
CORS_ORIGIN=http://localhost:5173

# Max recipes per day before new jobs are refused (quota defense). ~2 Gemini calls each.
BUDGET_DAILY_MAX=180
